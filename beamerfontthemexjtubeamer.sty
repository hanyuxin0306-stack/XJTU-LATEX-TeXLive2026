\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerfontthemexjtubeamer}[2023/05/28 v1.0.0 xjtubeamer font theme]

%%%%%%%%%%%
%% FONTS %%
%%%%%%%%%%%

\RequirePackage{silence}
\RequirePackage{unicode-math}

\WarningFilter{latexfont}{Font shape}
\WarningFilter{latexfont}{Some font shapes were not available}
\WarningFilter{xeCJK}{Redefining CJKfamily}
\ExplSyntaxOn
\msg_redirect_name:nnn { xeCJK } { CJKfamily-redef } { none }
\ExplSyntaxOff
\usefonttheme{professionalfonts}
\usefonttheme{structurebold}
\setbeamerfont{part name}{size=\normalsize}
\setbeamerfont{section name}{size=\normalsize}
\setbeamerfont{subsection name}{size=\normalsize}
\setbeamerfont{footnote}{size=\scriptsize}

\RequirePackage{ifplatform}
\ifwindows
  \setCJKmainfont[AutoFakeBold=true,AutoFakeSlant=true]{SimSun}
  \setCJKsansfont[AutoFakeBold=false,AutoFakeSlant=true]{SimHei}
  \IfFileExists{C:/Users/Hello/AppData/Local/Microsoft/Windows/Fonts/STKaiti.ttf}
    {
      \newfontfamily{\kaiti}[
        Path = C:/Users/Hello/AppData/Local/Microsoft/Windows/Fonts/,
        UprightFont = STKaiti.ttf,
        BoldFont = STKaiti.ttf,
        ItalicFont = STKaiti.ttf,
        BoldItalicFont = STKaiti.ttf,
        AutoFakeBold = true,
        AutoFakeSlant = true
      ]{STKaiti.ttf}
    }
    {
      \PackageError{xjtubeamer}
        {Required font file C:/Users/Hello/AppData/Local/Microsoft/Windows/Fonts/STKaiti.ttf not found}
        {Install STKaiti.ttf for the current user or update the font path in beamerfontthemexjtubeamer.sty.}
    }
  \setmainfont{XITS}
  \setsansfont{XITS}
  \setmathfont{XITS Math}
  \setmathfont[range={\mathcal,\mathbfcal},StylisticSet=1]{XITS Math}
\else
  \ifmacosx
    \setCJKmainfont[AutoFakeBold=true,AutoFakeSlant=true]{Songti SC}
    \setCJKsansfont[AutoFakeBold=false,AutoFakeSlant=true]{Heiti SC}
    \newfontfamily{\kaiti}{Kaiti SC}
    \setmainfont{XITS}
    \setsansfont{XITS}
    \setmathfont{XITS Math}
    \setmathfont[range={\mathcal,\mathbfcal},StylisticSet=1]{XITS Math}
  \else
    % 若使用方正字体需要自行下载并配置路径
    % \setCJKmainfont[AutoFakeBold=true,Path=/usr/local/share/fonts/]{fzsong.ttf}
    % \setCJKsansfont[AutoFakeBold=false,Path=/usr/local/share/fonts/]{fzhei.ttf}
    % \newfontfamily{\kaiti}{STKaiti}
    \setCJKmainfont[AutoFakeBold=true,AutoFakeSlant=true]{FandolSong}
    \setCJKsansfont[AutoFakeBold=false,AutoFakeSlant=true]{Source Han Sans SC}
    \setmainfont{XITS}
    \setsansfont{XITS}
    \setmathfont{XITS Math}
    \setmathfont[range={\mathcal,\mathbfcal},StylisticSet=1]{XITS Math}
  \fi
\fi



\endinput

